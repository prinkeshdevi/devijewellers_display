rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Public Rates 
    match /system/{document=**} {
      allow read: if true; 
      allow write: if request.auth != null; // Allowing any authenticated user to update for now
    }
  }
}
